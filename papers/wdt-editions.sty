% wdt-editions.sty — Edition and stream system for Wild Duck Theories papers
%
% CONCEPTS
% --------
% Streams are an INPUT concept: they tag content at authoring time.
%   \streambegin{lean} ... \streamend{lean}
%   \streambegin{metaphorical} ... \streamend{metaphorical}
%
% Editions are an OUTPUT concept: they declare which streams are enabled.
%   \enablestream{academic}
%   \enablestream{lean}
%   (metaphorical not enabled -> suppressed)
%
% Untagged content always flows through regardless of stream settings.
% Tagged content is shown only when its stream is enabled.
%
% STANDARD STREAMS
% ----------------
%   academic       — theorems, lemmas, proofs, definitions (always enabled in
%                  all meaningful editions; untagged content is implicitly academic)
%   lean         — Lean 4 source blocks and certificates
%   metaphorical — literary/allegorical prose (GEB/Thompson/Pirsig register):
%                  epigraphs, footnotes with voice, the Interlude, author remarks
%   working      — author-facing proof sketches, editorial notes, open questions
%   plain        — plain English glosses for general readers
%
% STANDARD EDITIONS (defined via \enablestream calls in driver documents)
% -----------------------------------------------------------------------
%   source       — all streams enabled (academic + lean + metaphorical + working)
%   literate     — academic + lean (source minus working notes)
%   academic     — academic only (no lean, no metaphorical, no working)
%   rich         — academic + metaphorical (no lean, no working)
%
% See papers/EDITIONS.md for full edition maintenance rules.
%
% USAGE IN DRIVER DOCUMENTS
% -------------------------
%   \def\currentedition{source}
%   \enablestream{academic}
%   \enablestream{lean}
%   \enablestream{metaphorical}
%   \enablestream{working}
%   \usepackage{../wdt-editions}
%   \input{wdt-structural-conjecture}
%
% GRANULARITY
% -----------
% Streams can be tagged at any granularity — around whole sections, individual
% theorem blocks, or single sentences. The driver document does not need to
% know the granularity; it just enables the streams it wants.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{wdt-editions}[2026/05/29 WDT Edition and Stream System v2]

\RequirePackage{xstring}
\RequirePackage{draftwatermark}

% ---- Edition ----

\providecommand{\currentedition}{source}

% \ifedition{edition}{content}
\newcommand{\ifedition}[2]{%
  \edef\wdt@ename{#1}%
  \edef\wdt@ecur{\currentedition}%
  \ifx\wdt@ename\wdt@ecur #2\fi%
}

% \foreditions{ed1,ed2,...}{content}
\newcommand{\foreditions}[2]{%
  \IfSubStr{,#1,}{,\currentedition,}{#2}{}%
}

% ---- Stream enable/disable ----

% Internal list of enabled streams, comma-delimited, with guard commas.
% \providecommand so a driver can pre-initialise before \usepackage if needed,
% but the normal pattern is to call \enablestream after \usepackage.
\providecommand{\wdt@enabledstreams}{,}

% \enablestream{name} — add name to the enabled set.
\newcommand{\enablestream}[1]{%
  \edef\wdt@enabledstreams{\wdt@enabledstreams#1,}%
}

% \isstreamenabled{name} — true if name is in the enabled set.
% Usage: \isstreamenabled{lean}{\LaTeX code}
\newcommand{\isstreamenabled}[2]{%
  \IfSubStr{\wdt@enabledstreams}{,#1,}{#2}{}%
}

% \streambegin{name} ... \streamend{name}
%   Show enclosed content only when stream name is enabled.
%   When suppressed, content is discarded into a void vbox.
\newcommand{\streambegin}[1]{%
  \IfSubStr{\wdt@enabledstreams}{,#1,}{%
    % stream enabled — content flows normally
  }{%
    % stream disabled — open void group to discard content
    \setbox0=\vbox\bgroup\ignorespaces
  }%
}

\newcommand{\streamend}[1]{%
  \IfSubStr{\wdt@enabledstreams}{,#1,}{%
    % stream was enabled — nothing to close
  }{%
    % close the void group
    \egroup
  }%
}

% Legacy single-stream interface — \currentstream{name} enables only that stream.
% Provided for backwards compatibility with driver documents that predate v2.
% New drivers should use \enablestream directly.
\newcommand{\currentstream}[1]{%
  \renewcommand{\wdt@enabledstreams}{,#1,}%
}

% ---- Watermark (edition-driven) ----

\SetWatermarkScale{3}
\SetWatermarkColor[gray]{0.88}

\ifedition{source}{\SetWatermarkText{}}
\ifedition{literate}{\SetWatermarkText{}}
\ifedition{academic}{\SetWatermarkText{DRAFT}}
\ifedition{rich}{\SetWatermarkText{DRAFT}}
\ifedition{working}{\SetWatermarkText{WORKING}}
% Legacy editions
\ifedition{academic-strict}{\SetWatermarkText{DRAFT}}
\ifedition{academic-liberal}{\SetWatermarkText{DRAFT}}
\ifedition{plain}{\SetWatermarkText{DRAFT}}
\ifedition{lean}{\SetWatermarkText{}}
\ifedition{metaphorical}{\SetWatermarkText{DRAFT}}
\ifedition{archived}{\SetWatermarkText{ARCHIVED}}
